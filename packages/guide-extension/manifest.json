{
  "manifest_version": 3,
  "name": "SOMA Guide — Ariadne",
  "version": "1.0.0",
  "description": "Inject the SOMA guide widget (Ariadne) into any web page on demand.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_title": "Summon Ariadne",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["vendor/soma-guide.js", "vendor/soma-guide.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
